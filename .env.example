# Shared repo settings
ADMIN_HOST=0.0.0.0
ADMIN_PORT=3000
ADMIN_SERVE_USER_BUILD=true
ADMIN_USER_ROUTE=/user

# Full source repository used by the Source App.
ADMIN_GIT_REPO_PATH=.
ADMIN_GIT_REMOTE=origin
ADMIN_GIT_DEFAULT_BRANCH=

# Separate public-data repository used by the DB Manager.
# This repo can belong to a different GitHub account.
ADMIN_DB_REPO_PATH=
ADMIN_DB_REMOTE=origin
ADMIN_DB_DEFAULT_BRANCH=

# Folder names inside the public-data repository.
ADMIN_DB_BASIC_TARGET=basic
ADMIN_DB_DETAILED_TARGET=detailed

# User app development and build settings
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_ADMIN_API_ORIGIN=http://localhost:3000
VITE_USER_BASE=/user/

# Public data source
# Leave blank to use the local admin API.
VITE_PUBLIC_DATA_ROOT=
# Example:
# VITE_PUBLIC_DATA_ROOT=https://raw.githubusercontent.com/<github-username>/<repo-name>/<branch>/data
