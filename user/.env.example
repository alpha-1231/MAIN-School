# User app environment file.
# Copy this file to user/.env and keep only public/frontend settings here.
VITE_PUBLIC_DATA_ROOT=
# Use a GitHub Raw folder URL, not a github.com/tree/... page URL.
VITE_ADMIN_API_ORIGIN=http://localhost:3000
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
# Use / when the public site is deployed on the domain root.
VITE_USER_BASE=/user/
VITE_SITE_NAME=AboutMySchool
VITE_SITE_ORIGIN=https://aboutmyschool.com
